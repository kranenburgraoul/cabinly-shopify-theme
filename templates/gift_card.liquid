<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'Gift card' }} — {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Outfit:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root { --navy: #1F3554; --sand: #F5F1E8; --olive: #7A826A; }
    body { font-family: 'Outfit', sans-serif; background: var(--sand); color: #2B2B2B; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; margin: 0; }
    .gift-card { max-width: 480px; width: 100%; text-align: center; }
    .gift-card__logo { font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--navy); margin-bottom: 2rem; }
    .gift-card__logo span { color: var(--olive); }
    .gift-card__card { background: var(--navy); border-radius: 12px; padding: 2.5rem; margin-bottom: 2rem; }
    .gift-card__amount { font-family: 'Cormorant Garamond', serif; font-size: 3rem; font-weight: 300; color: var(--sand); }
    .gift-card__code { font-size: 1.5rem; letter-spacing: .2em; color: var(--sand); margin-top: 1.5rem; font-weight: 500; background: rgba(255,255,255,.1); padding: .75rem 1.5rem; border-radius: 4px; }
    h1 { font-family: 'Cormorant Garamond', serif; color: var(--navy); margin-bottom: .5rem; }
    p { color: #666; font-size: .9rem; }
    .btn { display: inline-block; padding: .875rem 2rem; background: var(--navy); color: var(--sand); text-decoration: none; border-radius: 2px; font-size: .82rem; letter-spacing: .08em; text-transform: uppercase; margin-top: 1.5rem; }
  </style>
  {{ content_for_header }}
</head>
<body>
  <div class="gift-card">
    <div class="gift-card__logo">cabin<span>ly</span></div>
    <div class="gift-card__card">
      <div class="gift-card__amount">{{ gift_card.initial_value | money }}</div>
      <div class="gift-card__code">{{ gift_card.code | format_code }}</div>
    </div>
    <h1>Gift Card</h1>
    <p>Huidig saldo: {{ gift_card.balance | money }}</p>
    {% if gift_card.expired %}
      <p style="color:#c0392b;">Deze cadeaubon is verlopen op {{ gift_card.expires_on | date: '%d-%m-%Y' }}.</p>
    {% endif %}
    <a href="{{ shop.url }}" class="btn">Shop nu</a>
  </div>
</body>
</html>
