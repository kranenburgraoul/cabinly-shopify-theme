<section class="section" style="background: var(--color-sand);">
  <div class="page-width">
    <div class="reveal" style="text-align:center;margin-bottom:3rem;">
      {%- if section.settings.label != blank -%}
        <p class="section-label section-label--center">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    <div class="stats-row">
      {% for block in section.blocks %}
        <div class="stat-item" {{ block.shopify_attributes }}>
          <div class="stat-item__number">{{ block.settings.number }}</div>
          <div class="stat-item__label">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats row",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "In cijfers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cabinly in cijfers"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "50k+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Tevreden reizigers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats row",
      "blocks": [
        { "type": "stat", "settings": { "number": "50k+", "label": "Tevreden reizigers" } },
        { "type": "stat", "settings": { "number": "4.9★", "label": "Gemiddelde beoordeling" } },
        { "type": "stat", "settings": { "number": "150+", "label": "Landen bereikbaar" } },
        { "type": "stat", "settings": { "number": "8", "label": "Essentiële producten" } }
      ]
    }
  ]
}
{% endschema %}
