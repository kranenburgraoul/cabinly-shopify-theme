<div class="page-hero">
  <div class="page-width">
    {%- if section.settings.label != blank -%}
      <p class="section-label">{{ section.settings.label }}</p>
    {%- endif -%}
    <h1>{{ section.settings.heading | default: page.title }}</h1>
    {%- if section.settings.subtext != blank -%}
      <p class="page-hero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label above heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use page title."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext / description"
    }
  ],
  "presets": [
    {
      "name": "Page hero"
    }
  ]
}
{% endschema %}
