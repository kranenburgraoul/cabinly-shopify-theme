{%- if section.settings.enabled -%}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="page-width">
    {% if section.settings.text != blank %}
      <span>
        {% if section.settings.link != blank %}
          <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
        {% else %}
          {{ section.settings.text }}
        {% endif %}
      </span>
    {% endif %}
  </div>
  {% if section.settings.show_close %}
    <button class="announcement-bar__close" aria-label="Close announcement">✕</button>
  {% endif %}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Announcement text",
      "default": "<p><strong>Gratis verzending</strong> bij bestellingen boven de €50 · 30 dagen retourgarantie</p>"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show close button",
      "default": false
    }
  ]
}
{% endschema %}
