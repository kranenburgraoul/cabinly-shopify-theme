<section class="section" style="background: var(--color-sand);">
  <div class="page-width">
    <div class="reveal" style="text-align:center;margin-bottom:3rem;">
      {%- if section.settings.label != blank -%}
        <p class="section-label section-label--center">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card reveal reveal-d{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="testimonial__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% for i in (1..5) %}
              <span aria-hidden="true">★</span>
            {% endfor %}
          </div>
          <p class="testimonial__text">{{ block.settings.quote }}</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar" aria-hidden="true">{{ block.settings.author | slice: 0 }}</div>
            <div>
              <div class="testimonial__name">{{ block.settings.author }}</div>
              <div class="testimonial__detail">{{ block.settings.detail }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Wat onze reizigers zeggen"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Eindelijk een merk dat het snapt. Mijn Cabinly packing cubes hebben compleet veranderd hoe ik inpak."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sophie K."
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Author detail",
          "default": "Citytrip lover · Amsterdam"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Eindelijk een merk dat het snapt. Mijn Cabinly packing cubes hebben compleet veranderd hoe ik inpak. Nooit meer chaos in mijn koffer.",
            "author": "Sophie K.",
            "detail": "Citytrip lover · Amsterdam"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "De toilettas is perfect. Alles past erin en hij hangt in elke badkamer. Precies wat ik zocht voor mijn zakenreizen.",
            "author": "Marcus V.",
            "detail": "Frequent flyer · Rotterdam"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Drie travel adapters besteld voor een familiereis. Allemaal perfect gewerkt in 4 landen. Topkwaliteit voor een eerlijke prijs.",
            "author": "Lena B.",
            "detail": "Gezinsreiziger · Utrecht"
          }
        }
      ]
    }
  ]
}
{% endschema %}
