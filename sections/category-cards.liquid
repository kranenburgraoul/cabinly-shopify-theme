<section class="section" style="background: var(--color-sand);">
  <div class="page-width">
    <div class="reveal">
      {%- if section.settings.label != blank -%}
        <p class="section-label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 style="margin-bottom:2.5rem;">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="category-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}"
           class="category-card reveal reveal-d{{ forloop.index }}"
           {{ block.shopify_attributes }}>
          <div class="category-card__bg" style="background: {{ block.settings.background_gradient | default: 'linear-gradient(160deg, #2a4060 0%, #1F3554 100%)' }};"></div>
          <div class="category-card__overlay"></div>
          {%- if block.settings.image -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}"
                 alt="{{ block.settings.image.alt | default: block.settings.title }}"
                 loading="lazy"
                 style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
          {%- endif -%}
          <div class="category-card__content">
            {%- if block.settings.icon != blank -%}
              <span class="category-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {%- endif -%}
            <div>
              <h3>{{ block.settings.title }}</h3>
              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description }}</p>
              {%- endif -%}
              <span class="category-card__link">{{ block.settings.link_label | default: 'Bekijk producten' }} →</span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category cards",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Shop per categorie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Wat heb jij nodig onderweg?"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image (optional)"
        },
        {
          "type": "text",
          "id": "background_gradient",
          "label": "Background gradient (CSS)",
          "default": "linear-gradient(160deg, #2a4060 0%, #1F3554 100%)",
          "info": "Used when no image is set."
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji icon",
          "default": "🗂️"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Organiseer"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Alles op zijn plek. Geen chaos meer in je koffer."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Bekijk producten"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category cards",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon": "🗂️",
            "title": "Organiseer",
            "description": "Alles op zijn plek. Geen chaos meer in je koffer.",
            "background_gradient": "linear-gradient(160deg, #2a4060 0%, #1F3554 100%)",
            "link_label": "Bekijk producten"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "✈️",
            "title": "Comfort",
            "description": "Rustiger aankomen. Beter slapen. Minder stress.",
            "background_gradient": "linear-gradient(160deg, #3d4a38 0%, #7A826A 100%)",
            "link_label": "Bekijk producten"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "⚡",
            "title": "Essentials",
            "description": "De basics die elke reiziger bij zich moet hebben.",
            "background_gradient": "linear-gradient(160deg, #4a3d30 0%, #6b5a45 100%)",
            "link_label": "Bekijk producten"
          }
        }
      ]
    }
  ]
}
{% endschema %}
