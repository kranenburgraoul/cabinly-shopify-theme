<div class="trust-bar">
  <div class="page-width">
    <div class="trust-bar__inner">
      {% for block in section.blocks %}
        <div class="trust-item" {{ block.shopify_attributes }}>
          {%- case block.settings.icon -%}
            {%- when 'shipping' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            {%- when 'return' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            {%- when 'shield' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- when 'card' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
            {%- when 'star' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {%- endcase -%}
          <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust bar",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping arrow" },
            { "value": "return", "label": "Return / refresh" },
            { "value": "shield", "label": "Shield / guarantee" },
            { "value": "card", "label": "Payment card" },
            { "value": "star", "label": "Star" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Gratis verzending v.a. €50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping", "text": "Gratis verzending v.a. \u20ac50" } },
        { "type": "trust_item", "settings": { "icon": "return", "text": "30 dagen retour" } },
        { "type": "trust_item", "settings": { "icon": "shield", "text": "2 jaar garantie" } },
        { "type": "trust_item", "settings": { "icon": "card", "text": "Veilig betalen" } }
      ]
    }
  ]
}
{% endschema %}
