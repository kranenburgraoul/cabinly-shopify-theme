<footer class="site-footer" role="contentinfo">
  <div class="page-width">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
          {% if settings.logo %}
            <img src="{{ settings.logo | image_url: height: 36 }}" alt="{{ shop.name }}" style="max-height:36px;filter:brightness(10);">
          {% else %}
            {%- assign brand = settings.brand_name | default: shop.name -%}
            {{ brand | slice: 0, brand.size | minus: 2 }}<span>{{ brand | slice: brand.size | minus: 2, 2 }}</span>
          {% endif %}
        </a>
        {% if section.settings.brand_description != blank %}
          <p>{{ section.settings.brand_description }}</p>
        {% endif %}
      </div>

      <!-- Menu columns -->
      {% for i in (1..3) %}
        {%- assign menu_id = 'menu_' | append: i -%}
        {%- assign title_id = 'menu_title_' | append: i -%}
        {%- if section.settings[menu_id] != blank -%}
          <div class="footer-col">
            <h5>{{ section.settings[title_id] }}</h5>
            <ul role="list">
              {% for link in linklists[section.settings[menu_id]].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {%- endif -%}
      {% endfor %}

    </div>

    <div class="footer-bottom">
      <p>
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {% if section.settings.copyright_text != blank %}
          {{ section.settings.copyright_text }}
        {% endif %}
      </p>
      <div class="footer-socials">
        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" rel="noopener" target="_blank">Instagram</a>
        {% endif %}
        {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" rel="noopener" target="_blank">TikTok</a>
        {% endif %}
        {% if settings.social_pinterest != blank %}
          <a href="{{ settings.social_pinterest }}" rel="noopener" target="_blank">Pinterest</a>
        {% endif %}
        {% if settings.social_facebook != blank %}
          <a href="{{ settings.social_facebook }}" rel="noopener" target="_blank">Facebook</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium travel essentials voor reizigers die slimmer willen inpakken en comfortabeler willen reizen."
    },
    {
      "type": "text",
      "id": "menu_title_1",
      "label": "Column 1 title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Column 1 menu",
      "default": "footer-shop"
    },
    {
      "type": "text",
      "id": "menu_title_2",
      "label": "Column 2 title",
      "default": "Info"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Column 2 menu",
      "default": "footer-info"
    },
    {
      "type": "text",
      "id": "menu_title_3",
      "label": "Column 3 title",
      "default": "Service"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Column 3 menu",
      "default": "footer-service"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "Alle rechten voorbehouden."
    }
  ]
}
{% endschema %}
