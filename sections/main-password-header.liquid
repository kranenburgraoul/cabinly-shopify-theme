<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--color-navy);color:#fff;text-align:center;padding:2rem;">
  <div>
    <h1 style="font-family:var(--font-display);font-size:3rem;margin-bottom:1rem;">{{ shop.name }}</h1>
    <p style="opacity:.6;margin-bottom:2rem;">We zijn binnenkort online. Kom snel terug!</p>
    {% form 'storefront_password' %}
      <div style="display:flex;gap:.5rem;max-width:360px;margin:0 auto;">
        <input type="password" name="password" placeholder="Wachtwoord" style="flex:1;padding:.75rem 1rem;border:1px solid rgba(255,255,255,.3);background:transparent;color:#fff;border-radius:3px;">
        <button type="submit" style="padding:.75rem 1.5rem;background:var(--color-olive);color:#fff;border:none;border-radius:3px;cursor:pointer;">Toegang</button>
      </div>
      {{ form.errors | default_errors }}
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "limit": 1,
  "settings": []
}
{% endschema %}
