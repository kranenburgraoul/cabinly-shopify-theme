<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&family=Outfit:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-navy: {{ settings.color_navy | default: '#1F3554' }};
      --color-sand: {{ settings.color_sand | default: '#F5F1E8' }};
      --color-olive: {{ settings.color_olive | default: '#7A826A' }};
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Outfit', sans-serif;
      background: var(--color-navy);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
    }
    .password-inner { max-width: 480px; }
    .password-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem;
      font-weight: 500;
      color: var(--color-sand);
      letter-spacing: -.02em;
      margin-bottom: 2rem;
    }
    .password-logo span { color: var(--color-olive); }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      font-weight: 300;
      font-style: italic;
      color: var(--color-sand);
      margin-bottom: 1rem;
      line-height: 1.1;
    }
    p { color: rgba(245,241,232,.6); font-size: .95rem; margin-bottom: 2rem; line-height: 1.7; }
    form { display: flex; gap: 0; }
    input {
      flex: 1;
      padding: .875rem 1.25rem;
      background: rgba(245,241,232,.08);
      border: 1px solid rgba(245,241,232,.2);
      border-right: none;
      color: var(--color-sand);
      font-family: 'Outfit', sans-serif;
      font-size: .9rem;
      border-radius: 2px 0 0 2px;
      outline: none;
    }
    input::placeholder { color: rgba(245,241,232,.35); }
    button {
      background: var(--color-olive);
      color: #fff;
      border: none;
      padding: .875rem 1.5rem;
      font-size: .78rem;
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
      cursor: pointer;
      border-radius: 0 2px 2px 0;
      font-family: 'Outfit', sans-serif;
    }
  </style>
  {{ content_for_header }}
</head>
<body>
  <div class="password-inner">
    <div class="password-logo">cabin<span>ly</span></div>
    <h1>Coming soon.</h1>
    <p>We're working on something great. Enter your email to be notified when we launch.</p>
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter,password-page">
      <input type="email" name="contact[email]" placeholder="Your email address" required>
      <button type="submit">Notify me</button>
    {% endform %}
    {{ content_for_layout }}
  </div>
</body>
</html>
